generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  BUY
  SELL
  DEPOSIT
  WITHDRAW
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  name           String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  transactions   Transaction[]
  valuations     DailyValuation[]
}

model Asset {
  id             String           @id @default(uuid())
  ticker         String           @unique
  companyName    String
  currency       String           // e.g., "USD", "IDR"

  transactions   Transaction[]
}

model Transaction {
  id             String           @id @default(uuid())
  userId         String
  assetId        String?          // Nullable for DEPOSIT/WITHDRAW fiat movements
  type           TransactionType
  quantity       Decimal          @db.Decimal(19, 8) // Allows fractional shares
  executionPrice Decimal          @db.Decimal(19, 4) // Price per share at execution
  fee            Decimal          @db.Decimal(19, 4) @default(0) // Absolute fee value
  date           DateTime         @db.Date           // Trade execution date
  createdAt      DateTime         @default(now())    // System audit timestamp

  user           User             @relation(fields: [userId], references: [id])
  asset          Asset?           @relation(fields: [assetId], references: [id])

  // Indexes to prevent table-scans during daily Cron calculations
  @@index([userId])
  @@index([assetId])
  @@index([userId, date])
}

model DailyValuation {
  id             String           @id @default(uuid())
  userId         String
  date           DateTime         @db.Date
  
  // Equity
  cashBalanceUSD Decimal          @db.Decimal(19, 4)
  marketValueUSD Decimal          @db.Decimal(19, 4)
  totalEquityUSD Decimal          @db.Decimal(19, 4)
  
  // Converted Valuations
  totalEquityIDR Decimal          @db.Decimal(19, 2)
  exchangeRate   Decimal          @db.Decimal(19, 4) // USD to IDR rate at snapshot

  user           User             @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}